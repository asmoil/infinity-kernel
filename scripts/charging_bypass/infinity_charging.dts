/*
 * Infinity Charging Bypass DTS overlay
 * Compatible: qcom,sm8250 / qcom,sm8250-ac
 * Poco X3 Pro (vayu/bhima)
 */

/dts-v1/;
/plugin/;

/ {
    compatible = "qcom,sm8250";
};

&soc {
    infinity_charging: infinity_charging@0 {
        compatible = "qcom,sm8250";
        status = "okay";
    };
};