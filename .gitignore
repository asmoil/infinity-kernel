# Infinity Kernel - .gitignore for kernel + CI
# =====================================================================

# Kernel build outputs
out/
*.o
*.o.*
*.ko
*.ko.cmd
*.mod
*.mod.c
*.mod.cmd
*.cmd
*.order
*.symvers
*.markers
Module.symvers
modules.builtin
modules.order
.arch
.tmp_versions/
vmlinux
vmlinux.o
vmlinux.symvers
System.map
.build.log
build.log

# Boot images (regenerated by CI)
arch/arm64/boot/Image
arch/arm64/boot/Image.gz
arch/arm64/boot/Image.gz-dtb
arch/arm64/boot/dts/qcom/*.dtb
arch/arm64/boot/dtbo.img
dtb.img

# Toolchain
proton-clang/
prebuilts/

# AnyKernel3 output ZIPs
*.zip
*.md5sum
*.sha256

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.cproject
.project
.settings/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# CircleCI local
.circleci/local-test*

# ccache
.ccache/