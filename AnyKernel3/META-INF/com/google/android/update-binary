#!/sbin/sh

# ═══════════════════════════════════════════════════════════════
#  AnyKernel3 Update-Binary (shell-based)
#  Infinity Kernel — Poco X3 Pro (vayu/bhima)
# ═══════════════════════════════════════════════════════════════

OUTFD="$2"
ZIPFILE="$3"

# Detect output fd
readlink /proc/$$/fd/$OUTFD 2>/dev/null | grep -q /proc && OUTFD=""

ui_print() {
  if [ -z "$OUTFD" ]; then
    echo "$1"
  else
    echo "ui_print $1" >&"$OUTFD"
    echo "ui_print" >&"$OUTFD"
  fi
}

abort() {
  ui_print " "
  ui_print "!!! INSTALLATION ABORTED !!!"
  ui_print "$1"
  ui_print " "
  exit 1
}

show_progress() {
  if [ -n "$OUTFD" ]; then
    echo "progress $1 $2" >&"$OUTFD"
  fi
}

# Mount partitions
mount_partitions() {
  [ -f /etc/recovery.fstab ] && fstab="/etc/recovery.fstab"
  [ -z "$fstab" ] && [ -f /etc/recovery.fstab.bak ] && fstab="/etc/recovery.fstab.bak"
  if [ -n "$fstab" ]; then
    system_mount=$(grep ' /system ' "$fstab" | head -1)
    system_mount="${system_mount#* }"
    system_mount="${system_mount%% *}"
    vendor_mount=$(grep ' /vendor ' "$fstab" | head -1)
    vendor_mount="${vendor_mount#* }"
    vendor_mount="${vendor_mount%% *}"
  fi
  [ -z "$system_mount" ] && system_mount="/dev/block/bootdevice/by-name/system"
  [ -z "$vendor_mount" ] && vendor_mount="/dev/block/bootdevice/by-name/vendor"
  mount -o ro "$system_mount" /system 2>/dev/null || mount -o ro /system 2>/dev/null
  mount -o ro "$vendor_mount" /vendor 2>/dev/null || mount -o ro /vendor 2>/dev/null
}

# Detect slot for A/B devices
detect_slot() {
  if [ -d /system/system ]; then
    SLOT="_a"
  elif [ ! -d /system/vendor ] && [ -d /system ]; then
    SLOT="_a"
  else
    SLOT=$(getprop ro.boot.slot_suffix 2>/dev/null)
    [ -z "$SLOT" ] && SLOT=$(cat /proc/cmdline 2>/dev/null | grep -o 'androidboot.slot_suffix=[a-z]*' | head -1 | cut -d= -f2)
    [ -z "$SLOT" ] && SLOT="_a"
  fi
  export SLOT
}

# Main
umount /system 2>/dev/null
umount /vendor 2>/dev/null

show_progress 0.1 0
ui_print " "
ui_print "   Infinity Kernel Installer"
ui_print "   Poco X3 Pro (vayu/bhima)"
ui_print " "

mount_partitions
detect_slot
ui_print "Slot: ${SLOT}"
ui_print " "

# Create tmpdir and extract
TMPDIR="/dev/tmp"
rm -rf "$TMPDIR/anykernel"
mkdir -p "$TMPDIR/anykernel"

show_progress 0.2 5
cd "$TMPDIR"
unzip -o "$ZIPFILE" -d anykernel 2>/dev/null

# Source anykernel.sh
[ -f "$TMPDIR/anykernel/anykernel.sh" ] || abort "anykernel.sh not found!"
. "$TMPDIR/anykernel/anykernel.sh"

show_progress 1.0 10