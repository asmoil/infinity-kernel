+#ifdef CONFIG_SUSFS
+/*
+ * SUSFS global state for root hiding.
+ * Root managers (KernelSU, APatch) populate these at runtime via
+ * the exported symbols below.  All access is serialized by susfs_lock.
+ */
+DEFINE_SPINLOCK(susfs_lock);
+int susfs_enabled;
+EXPORT_SYMBOL_GPL(susfs_enabled);
+
+unsigned long susfs_spoof_uid_map[SUSFS_PID_MAP_SIZE / BITS_PER_LONG];
+EXPORT_SYMBOL_GPL(susfs_spoof_uid_map);
+
+struct susfs_spoof_path_entry susfs_spoof_paths[SUSFS_MAX_ENTRIES];
+EXPORT_SYMBOL_GPL(susfs_spoof_paths);
+
+struct susfs_hide_path_entry susfs_hide_paths[SUSFS_MAX_ENTRIES];
+EXPORT_SYMBOL_GPL(susfs_hide_paths);
+
+struct susfs_mount_hide_entry susfs_mount_hides[SUSFS_MAX_ENTRIES];
+EXPORT_SYMBOL_GPL(susfs_mount_hides);
+
+EXPORT_SYMBOL_GPL(susfs_is_enabled);
+EXPORT_SYMBOL_GPL(susfs_should_spoof_uid);
+EXPORT_SYMBOL_GPL(susfs_set_spoof_uid);
+EXPORT_SYMBOL_GPL(susfs_should_hide_path);
+EXPORT_SYMBOL_GPL(susfs_get_spoof_magic);
+EXPORT_SYMBOL_GPL(susfs_should_hide_mount);
+EXPORT_SYMBOL_GPL(susfs_lock);
+
+/*
+ * Check if a mount entry should be skipped in /proc/self/mounts.
+ * Returns 1 to skip (SEQ_SKIP), 0 to show.
+ *
+ * Root managers call this from a wrapper .show seq_operation:
+ *   if (susfs_mounts_should_skip(m, v))
+ *       return SEQ_SKIP;
+ *   return orig_show(m, v);
+ *
+ * The v parameter is the struct mount * from the seq_file iterator.
+ */
+int susfs_mounts_should_skip(struct seq_file *m, void *v)
+{
+	struct mount *mnt = v;
+	char buf[SUSFS_PATH_MAX_LEN];
+	char *p;
+
+	if (!susfs_is_enabled() || !mnt)
+		return 0;
+	p = d_path(&mnt->mnt, buf, sizeof(buf));
+	if (!IS_ERR(p) && (susfs_should_hide_mount(p) ||
+	    susfs_is_adb_bind_mount(p)))
+		return 1;
+	return 0;
+}
+EXPORT_SYMBOL_GPL(susfs_mounts_should_skip);
+#endif /* CONFIG_SUSFS */
