diff --git a/include/linux/susfs.h b/include/linux/susfs.h
new file mode 100644
index 0000000..abcdef0
--- /dev/null
+++ b/include/linux/susfs.h
@@ -0,0 +1,130 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * SUSFS - Systemless Universal System File Spoofing v1.5.7+
+ *
+ * Kernel-level root hiding infrastructure for KernelSU, APatch,
+ * and compatible root managers.  All hooks compiled out when
+ * CONFIG_SUSFS is not set.
+ *
+ * Copyright (c) 2024 Infinity Kernel <infinity@vayu>
+ */
+#ifndef _LINUX_SUSFS_H
+#define _LINUX_SUSFS_H
+
+#include <linux/types.h>
+#include <linux/spinlock.h>
+#include <linux/fs.h>
+#include <linux/mount.h>
+#include <linux/uidgid.h>
+#include <linux/kernel.h>
+#include <linux/seq_file.h>
+
+#ifdef CONFIG_SUSFS
+
+#define SUSFS_VERSION		"1.5.7"
+#define SUSFS_ENABLED
+#define SUSFS_MAX_ENTRIES	64
+#define SUSFS_PATH_MAX_LEN	256
+#define SUSFS_PID_MAP_SIZE	32768
+#define SUSFS_PID_MAP_BITS	(SUSFS_PID_MAP_SIZE * BITS_PER_LONG)
+
+/* Default spoof UID/GID (unprivileged app user) */
+#define SUSFS_SPOOF_UID	KUIDT_INIT(10000)
+#define SUSFS_SPOOF_GID	KGIDT_INIT(10000)
+
+struct susfs_spoof_path_entry {
+	char path[SUSFS_PATH_MAX_LEN];
+	u32 spoof_magic;
+	bool active;
+};
+
+struct susfs_hide_path_entry {
+	char path[SUSFS_PATH_MAX_LEN];
+	bool active;
+};
+
+struct susfs_mount_hide_entry {
+	char mountpoint[SUSFS_PATH_MAX_LEN];
+	bool active;
+};
+
+/* Global state defined in fs/proc/base.c */
+extern spinlock_t susfs_lock;
+extern int susfs_enabled;
+extern unsigned long susfs_spoof_uid_map[];
+extern struct susfs_spoof_path_entry susfs_spoof_paths[];
+extern struct susfs_hide_path_entry susfs_hide_paths[];
+extern struct susfs_mount_hide_entry susfs_mount_hides[];
+
+static inline bool susfs_is_enabled(void) { return susfs_enabled; }
+
+static inline bool susfs_should_spoof_uid(pid_t pid)
+{
+	bool ret;
+	unsigned long flags;
+	spin_lock_irqsave(&susfs_lock, flags);
+	ret = test_bit(pid % SUSFS_PID_MAP_BITS, susfs_spoof_uid_map);
+	spin_unlock_irqrestore(&susfs_lock, flags);
+	return ret;
+}
+
+static inline void susfs_set_spoof_uid(pid_t pid, bool val)
+{
+	unsigned long flags;
+	spin_lock_irqsave(&susfs_lock, flags);
+	if (val)
+		set_bit(pid % SUSFS_PID_MAP_BITS, susfs_spoof_uid_map);
+	else
+		clear_bit(pid % SUSFS_PID_MAP_BITS, susfs_spoof_uid_map);
+	spin_unlock_irqrestore(&susfs_lock, flags);
+}
+
+/* Hide check: matches full path or leaf component against hide list */
+static inline bool susfs_should_hide_path(const char *name)
+{
+	int i;
+	unsigned long flags;
+	bool ret = false;
+	if (!susfs_enabled || !name)
+		return false;
+	spin_lock_irqsave(&susfs_lock, flags);
+	for (i = 0; i < SUSFS_MAX_ENTRIES; i++) {
+		const char *leaf;
+		if (!susfs_hide_paths[i].active)
+			continue;
+		if (!strcmp(name, susfs_hide_paths[i].path))
+			{ ret = true; break; }
+		leaf = strrchr(susfs_hide_paths[i].path, '/');
+		if (leaf && !strcmp(name, leaf + 1))
+			{ ret = true; break; }
+	}
+	spin_unlock_irqrestore(&susfs_lock, flags);
+	return ret;
+}
+
+static inline u32 susfs_get_spoof_magic(const char *name)
+{
+	int i;
+	unsigned long flags;
+	u32 magic = 0;
+	if (!susfs_enabled || !name)
+		return 0;
+	spin_lock_irqsave(&susfs_lock, flags);
+	for (i = 0; i < SUSFS_MAX_ENTRIES; i++) {
+		if (!susfs_spoof_paths[i].active)
+			continue;
+		if (!strcmp(name, susfs_spoof_paths[i].path))
+			{ magic = susfs_spoof_paths[i].spoof_magic; break; }
+	}
+	spin_unlock_irqrestore(&susfs_lock, flags);
+	return magic;
+}
+
+static inline bool susfs_should_hide_mount(const char *path)
+{
+	int i;
+	unsigned long flags;
+	bool ret = false;
+	if (!susfs_enabled || !path)
+		return false;
+	spin_lock_irqsave(&susfs_lock, flags);
+	for (i = 0; i < SUSFS_MAX_ENTRIES; i++) {
+		if (susfs_mount_hides[i].active &&
+		    !strcmp(path, susfs_mount_hides[i].mountpoint))
+			{ ret = true; break; }
+	}
+	spin_unlock_irqrestore(&susfs_lock, flags);
+	return ret;
+}
+
+/* Auto-hide any mount originating from /data/adb (bind mounts) */
+static inline bool susfs_is_adb_bind_mount(const char *path)
+{
+	return path && strstr(path, "/data/adb") != NULL;
+}
+
+#else /* !CONFIG_SUSFS */
+static inline bool susfs_is_enabled(void) { return false; }
+#endif /* CONFIG_SUSFS */
+
+#endif /* _LINUX_SUSFS_H */
diff --git a/kernel/fork.c b/kernel/fork.c
index 5678901..def0123 100644
--- a/kernel/fork.c
+++ b/kernel/fork.c
@@ -81,6 +81,9 @@
 #include <linux/kcov.h>
 #include <linux/livepatch.h>
 #include <linux/cleancache.h>
+#ifdef CONFIG_SUSFS
+#include <linux/susfs.h>
+#endif
 
 #include <asm/pgtable.h>
 #include <asm/pgalloc.h>
@@ -1919,6 +1922,14 @@ static __latent_entropy struct task_struct *copy_process(
 	if (retval)
 		goto bad_fork_cleanup_io;
 
+#ifdef CONFIG_SUSFS
+	/*
+	 * SUSFS: inherit UID spoof flag from parent so cloned
+	 * processes (fork, clone, vfork) remain hidden.
+	 */
+	if (susfs_is_enabled() && susfs_should_spoof_uid(current->pid))
+		susfs_set_spoof_uid(p->pid, true);
+#endif
+
 	/* Don't allow children to exceed the parent's resource limits. */
 	retval = pdeath_signal;
 	if (!(clone_flags & CLONE_PARENT_SETTID))
