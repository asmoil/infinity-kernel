From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Infinity Kernel <infinity@kernel.dev>
Date: Thu, 1 Jan 2025 00:00:00 +0000
Subject: [PATCH 06/10] module: root manager support (KernelSU, KSU Next,
 Magisk, APatch, ReSukiSu, SukiSU Ultra)

Add module allowlist that bypasses signature verification and vermagic
checks for known root manager kernel modules:
  - KernelSU / KernelSU Next
  - Magisk
  - APatch / KP (kernel patch)
  - ReSukiSu / SukiSU Ultra

Also export kallsyms_lookup_name which is required by KernelSU and
APatch for internal kernel symbol resolution.

Changes:
- kernel/module.c: add module_is_allowlisted() helper
- kernel/module.c: bypass module_sig_check() for allowlisted modules
- kernel/module.c: bypass check_modinfo() vermagic for allowlisted modules
- kernel/kallsyms.c: export kallsyms_lookup_name via EXPORT_SYMBOL_GPL

Signed-off-by: Infinity Kernel <infinity@kernel.dev>
---
 kernel/kallsyms.c |    +1
 kernel/module.c   |   +38
 2 files changed, 39 insertions(+), 0 deletions(-)

--- a/kernel/module.c
+++ b/kernel/module.c
@@ -68,15 +68,42 @@
 EXPORT_SYMBOL_GPL(module_mutex);
 static LIST_HEAD(modules);
 
 #ifdef CONFIG_KGDB_KDB
 struct list_head *kdb_modules = &modules;
 EXPORT_SYMBOL_GPL(kdb_modules);
 #endif
 
+/* Root manager module allowlist - bypass sig/vermagic checks */
+static bool module_is_allowlisted(const char *name)
+{
+	static const char * const allowed_modules[] = {
+		"kernelsu",		/* KernelSU */
+		"kernelsu_next",	/* KernelSU Next */
+		"magisk",		/* Magisk */
+		"apatch",		/* APatch */
+		"kp",			/* APatch kernel patch */
+		"resukisu",		/* ReSukiSu */
+		"sukisu_ultra",		/* SukiSU Ultra */
+		NULL
+	};
+	int i;
+
+	if (!name)
+		return false;
+
+	for (i = 0; allowed_modules[i]; i++) {
+		if (strstr(name, allowed_modules[i]))
+			return true;
+	}
+
+	return false;
+}
+
+
 #ifdef CONFIG_MODULES_TREE_LOOKUP
 static BLOCKING_NOTIFIER_HEAD(module_notify_list);
 #endif
 
 /* Block module loading/unloading? */
 int modules_disabled = 0;
 core_param(nomodules, modules_disabled, bint, 0);
@@ -2088,12 +2115,16 @@
 static int check_modinfo(struct module *mod,
 			  struct load_info *info, int flags)
 {
 	const char *modname = get_modinfo(info, "name");
+
+	/* Skip vermagic check for root manager modules */
+	if (module_is_allowlisted(get_modinfo(info, "name")))
+		return 0;
 
 	if (flags & MODULE_INIT_IGNORE_VERMAGIC)
 		modname = NULL;
 
 	if (modname) {
 		if (!have_modern_vermagic(modname)) {
 			pr_warn("%s: module magic version '%s' should be %s\n",
 				mod->name, modname, VERMAGIC_STRING);
@@ -2370,11 +2401,18 @@
 static int module_sig_check(struct load_info *info, int flags)
 {
 	int err = -ENOMODULE;
+
+	/* Bypass signature check for root manager modules */
+	{
+		const char *modname = get_modinfo(info, "name");
+		if (modname && module_is_allowlisted(modname))
+			return 0;
+	}
 
 	const unsigned long marker[2] = {MODULE_SIG_STRING, MODULE_SIG_STRING};
 	const void *mod = info->hdr;
 	const void *sig = mod + info->len - marker_size(sizeof(marker));
 
 	if (info->len <= marker_size(sizeof(marker)))
 		return 0;
 
--- a/kernel/kallsyms.c
+++ b/kernel/kallsyms.c
@@ -158,11 +158,12 @@
 		addr = kallsyms_sym_address(i);
 		if (strcmp(kallsyms_names[i], name) == 0)
 			return addr;
 	}
 
 	return module_kallsyms_lookup_name(name);
 }
 
+EXPORT_SYMBOL_GPL(kallsyms_lookup_name);
 static unsigned long kallsyms_lookup_size_offset(unsigned long addr,
 						  unsigned long *symbolsize,
 						  unsigned long *offset)
