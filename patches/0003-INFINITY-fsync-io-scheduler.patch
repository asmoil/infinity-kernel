From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Infinity Kernel Team <infinity@kernel.dev>
Date: Thu, 12 Jun 2025 00:00:00 +0000
Subject: [PATCH 03/10] INFINITY: FSYNC & IO Scheduler Optimization

Optimizations:
- Maple IO scheduler as default (best for flash storage)
- FSYNC support for gaming (reduced input latency)
- BFQ as fallback with tuned budgets
- I/O priority boosting for foreground apps
- Read-ahead optimization for sequential reads
- NVMe/UFS queue depth tuning

Signed-off-by: Infinity Kernel Team <infinity@kernel.dev>
---
 block/Kconfig.iosched    | 24 ++++++++++++++++++++++++
 block/elevator.c         | 12 ++++++++++++
 block/kyber-iosched.c    | 10 +++++-----
 block/mq-deadline.c      |  8 ++++----
 fs/sync.c                | 20 ++++++++++++++++++++
 5 files changed, 65 insertions(+), 9 deletions(-)

diff --git a/block/Kconfig.iosched b/block/Kconfig.iosched
index abcdef0123..abcdef4567 100644
--- a/block/Kconfig.iosched
+++ b/block/Kconfig.iosched
@@ -2,6 +2,16 @@
 # IO scheduler configuration
 #

+config IOSCHED_MAPLE
+	tristate "Maple I/O scheduler"
+	default y
+	help
+	  Maple is a budget-based I/O scheduler designed for mobile
+	  devices with flash storage. It provides better throughput
+	  and latency characteristics compared to CFQ/BFQ for
+	  typical Android workloads (app launch, gaming, browsing).
+
+	  Infinity Kernel recommends Maple as the default scheduler.
+
 config IOSCHED_NOOP
 	tristate "No-op I/O scheduler"
 	default y
@@ -79,6 +89,20 @@ config DEFAULT_IOSCHED
 	default "deadline" if DEFAULT_DEADLINE
 	default "cfq" if DEFAULT_CFQ

+config INFINITY_IO_SCHED_BOOST
+	bool "Infinity Kernel IO Scheduler Boosting"
+	depends on BLK_CGROUP
+	default y if INFINITY_KERNEL
+	help
+	  Enable IO priority boosting for foreground applications
+	  and games. This gives higher IO priority to the foreground
+	  task, reducing I/O-related jank and improving game
+	  frame stability.
+
+config INFINITY_READAHEAD
+	int "Infinity Kernel readahead size (KB)"
+	default 128
+	help
+	  Read-ahead size in KB for sequential I/O patterns.
+	  Higher values improve sequential read performance
+	  at the cost of some memory.
+
 endchoice

diff --git a/block/elevator.c b/block/elevator.c
index bcdef01234..bcdef34567 100644
--- a/block/elevator.c
+++ b/block/elevator.c
@@ -23,6 +23,10 @@
 #include "blk.h"
 #include "blk-mq-sched.h"

+#ifdef CONFIG_INFINITY_IO_SCHED_BOOST
+#include <linux/cgroup.h>
+#endif
+
 static DEFINE_SPINLOCK(elv_list_lock);
 static LIST_HEAD(elv_list);

@@ -142,6 +146,14 @@ struct request *elv_former_request(struct request_queue *q,
 }
 EXPORT_SYMBOL(elv_former_request);

+#ifdef CONFIG_INFINITY_IO_SCHED_BOOST
+/*
+ * infinity_io_boost - Boost I/O priority for foreground tasks
+ *
+ * Called from the scheduler to give foreground apps (games, UI)
+ * higher I/O priority. This reduces I/O stalls that cause
+ * frame drops in games.
+ */
+static inline void infinity_io_boost(struct request_queue *q)
+{
+	struct task_struct *task = current;
+
+	/* Only boost for regular (non-kernel) tasks */
+	if (task->prio >= MAX_RT_PRIO) {
+		/* Boost the request to higher priority class */
+		if (q->sched_data)
+			blkcg_set_prio_boost(task, 1);
+	}
+}
+#endif
+
 int elv_register_queue(struct request_queue *q, bool uevent)
 {
 	struct elevator_queue *e = q->elevator;
