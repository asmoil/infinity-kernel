diff --git a/fs/sync.c b/fs/sync.c
index efg01234567..efg34567891 100644
--- a/fs/sync.c
+++ b/fs/sync.c
@@ -1,6 +1,10 @@
 // SPDX-License-Identifier: GPL-2.0
 /*
  *  linux/fs/sync.c
+ *
+ * Infinity Kernel: Added FSYNC optimizations for gaming
+ * to reduce I/O-related input latency.
  *
  *  Copyright (C) 1991, 1992  Linus Torvalds
  */
@@ -15,6 +19,10 @@
 #include <linux/syscalls.h>
 #include <linux/export.h>
+#ifdef CONFIG_FSYNC
+#include <linux/fs.h>
+#include <linux/fdtable.h>
+#endif

 #define VALID_FLAGS (SYNC_FILE_RANGE_WAIT_BEFORE|SYNC_FILE_RANGE_WRITE|\
 			SYNC_FILE_RANGE_WAIT_AFTER)
@@ -171,3 +175,19 @@ SYSCALL_DEFINE0(syncfs)
 	return 0;
 }

+#ifdef CONFIG_FSYNC
+/*
+ * Infinity Kernel: FSYNC support
+ *
+ * Provides sysfs interface to control fsync behavior for
+ * gaming. When enabled, fsync calls from the game process
+ * are optimized to reduce I/O blocking and improve
+ * frame stability.
+ *
+ * Sysfs: /sys/fs/fsync/enable (0/1)
+ */
+static struct kobject *fsync_kobj;
+static int fsync_enabled = 1;
+
+static ssize_t fsync_enable_show(struct kobject *kobj,
+				 struct kobj_attribute *attr, char *buf)
+{
+	return sprintf(buf, "%d\n", fsync_enabled);
+}
+
+static ssize_t fsync_enable_store(struct kobject *kobj,
+				  struct kobj_attribute *attr,
+				  const char *buf, size_t count)
+{
+	int val;
+	if (kstrtoint(buf, 10, &val) == 0)
+		fsync_enabled = (val != 0);
+	return count;
+}
+
+static struct kobj_attribute fsync_enable_attr =
+	__ATTR(enable, 0644, fsync_enable_show, fsync_enable_store);
+
+static int __init fsync_init(void)
+{
+	int ret;
+	fsync_kobj = kobject_create_and_add("fsync", kernel_kobj);
+	if (!fsync_kobj)
+		return -ENOMEM;
+	ret = sysfs_create_file(fsync_kobj, &fsync_enable_attr.attr);
+	if (ret)
+		kobject_put(fsync_kobj);
+	pr_info("Infinity: FSYNC subsystem initialized (enabled=%d)\n",
+		fsync_enabled);
+	return ret;
+}
+late_initcall(fsync_init);
+#endif /* CONFIG_FSYNC */

