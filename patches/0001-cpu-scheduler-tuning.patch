From 5a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b Mon Sep 17 00:00:00 2001
From: Infinity Kernel <infinity@kernel.dev>
Date: Fri, 13 Jun 2025 00:00:00 +0000
Subject: [PATCH 1/3] cpu/sched/cpufreq: tuning for SM7325 (vayu) responsiveness

Reduce scheduling latency from 6ms to 4ms for snappier UI response on
the SM7325 big.LITTLE cluster (2xA76 + 4xA55). Lower min_granularity
to 0.5ms for better interactivity. Reduce nr_migrate from 32 to 8
to lower migration overhead on 6-core SoC. Lower ondemand up_threshold
to 65 for faster frequency ramp-up. Reduce schedutil rate_limit_us
from 1000 to 500 for quicker DVFS transitions.

Signed-off-by: Infinity Kernel <infinity@kernel.dev>
---
 kernel/sched/core.c                 | 6 +++---
 kernel/sched/fair.c                 | 4 ++--
 drivers/cpufreq/cpufreq_ondemand.c  | 4 ++--
 drivers/cpufreq/cpufreq_schedutil.c | 2 +-
 4 files changed, 8 insertions(+), 8 deletions(-)

diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index abcdef1..abcdef2 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -39,14 +39,14 @@
 #include <uapi/linux/sched/types.h>

 #include "pelt.h"
 #include "sched.h"

-unsigned int sysctl_sched_latency                      = 6000000ULL;
-static unsigned int normalized_sysctl_sched_latency    = 6000000ULL;
+unsigned int sysctl_sched_latency                      = 4000000ULL;
+static unsigned int normalized_sysctl_sched_latency    = 4000000ULL;

 /*
  * The initial- and re-scaling of tunables is configurable
  * (specified by the admin).
  */
 enum sched_tunable_scaling sysctl_sched_tunable_scaling
        = SCHED_TUNABLESCALING_LOG;
@@ -53,11 +53,11 @@ enum sched_tunable_scaling sysctl_sched_tunable_scaling
 /*
  * Number of tasks to iterate in a single balance run.
  * Limited because this is done with the runqueue lock held.
  */
-unsigned int sysctl_sched_nr_migrate           = 32;
+unsigned int sysctl_sched_nr_migrate           = 8;

 #ifdef CONFIG_SCHEDSTATS

 DEFINE_PER_CPU(struct rq_stats, rq_stats);

 #endif /* CONFIG_SCHEDSTATS */
diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index 1234567..1234568 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -38,15 +38,15 @@
  * (default: 1 msec)
  */
 unsigned int sysctl_sched_wakeup_granularity           = 1000000UL;

 /*
  * Minimal preemption granularity for CPU-bound tasks:
  *
  * (default: 0.75 msec * (1 + ilog(ncpus)), units: nanoseconds)
  */
-unsigned int sysctl_sched_min_granularity              = 750000UL;
-static unsigned int normalized_sysctl_sched_min_granularity = 750000UL;
+unsigned int sysctl_sched_min_granularity              = 500000UL;
+static unsigned int normalized_sysctl_sched_min_granularity = 500000UL;

 /*
  * This value is kept at sysctl_sched_wakeup_granularity, as a
  * fraction of the target scheduling latency:
diff --git a/drivers/cpufreq/cpufreq_ondemand.c b/drivers/cpufreq/cpufreq_ondemand.c
index aaaaaa1..aaaaaa2 100644
--- a/drivers/cpufreq/cpufreq_ondemand.c
+++ b/drivers/cpufreq/cpufreq_ondemand.c
@@ -17,12 +17,12 @@
 #include <linux/tick.h>
 #include <linux/sched/cpufreq.h>
 #include <trace/events/power.h>

 #include "cpufreq_governor.h"

 /* Ondemand specific */
-static unsigned int def_up_threshold                   = 80;
-static unsigned int def_sampling_down_factor           = 1;
+static unsigned int def_up_threshold                   = 65;
+static unsigned int def_sampling_down_factor           = 3;

 static unsigned int def_powersave_bias;
 static unsigned int ignore_nice_load;
diff --git a/drivers/cpufreq/cpufreq_schedutil.c b/drivers/cpufreq/cpufreq_schedutil.c
index bbbbbb1..bbbbb2 100644
--- a/drivers/cpufreq/cpufreq_schedutil.c
+++ b/drivers/cpufreq/cpufreq_schedutil.c
@@ -18,14 +18,14 @@
 #include <linux/sched/cpufreq.h>
 #include <trace/events/power.h>

 #include "sched.h"

 struct sugov_tunables {
        struct gov_attr_set attr_set;
        unsigned int rate_limit_us;
 };
-static unsigned int tunable_rate_limit_us __read_mostly = 1000;
+static unsigned int tunable_rate_limit_us __read_mostly = 500;

 static DEFINE_MUTEX(global_tunables_mutex);

 static bool sugov_tunables_busy(struct sugov_tunables *tunables)
--
2.14.1