From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Infinity Kernel Team <infinity@kernel.dev>
Date: Thu, 12 Jun 2025 00:00:00 +0000
Subject: [PATCH 01/10] INFINITY: CPU Performance Tuning

Optimizations:
- Interactive governor with boosted frequencies
- CPU boost on touch/input events
- Aggressive frequency ramp-up, relaxed ramp-down
- Heterogeneous multi-processing (HMP) optimizations
- Big/LITTLE cluster affinity tuning

Signed-off-by: Infinity Kernel Team <infinity@kernel.dev>
---
 drivers/cpufreq/Kconfig          |  12 +++
 drivers/cpufreq/cpufreq.c        |  32 +++++++
 drivers/cpufreq/cpufreq_ondemand.c | 85 ++++++++++++++++++++++++---
 3 files changed, 120 insertions(+), 9 deletions(-)

diff --git a/drivers/cpufreq/Kconfig b/drivers/cpufreq/Kconfig
index abcdef0123..abcdef4567 100644
--- a/drivers/cpufreq/Kconfig
+++ b/drivers/cpufreq/Kconfig
@@ -287,6 +287,18 @@ config CPU_FREQ_DEFAULT_GOV_PERFORMANCE
 	  performance. This governor is recommended for systems that
 	  require maximum performance.

+config CPU_FREQ_DEFAULT_GOV_INTERACTIVE
+	bool "interactive" if CPU_FREQ
+	select CPU_FREQ_GOV_INTERACTIVE
+	help
+	  Use the CPUFreq governor 'interactive' as default. This allows
+	  you to get a full dynamic frequency scaling with boosted
+	  responsiveness for input events. Ideal for gaming and
+	  interactive workloads while maintaining good battery life
+	  through smart frequency ramping.
+
+	  For Infinity Kernel, this is the recommended default.
+
 config CPU_FREQ_DEFAULT_GOV_POWERSAVE
 	bool "powersave" if CPU_FREQ
 	select CPU_FREQ_GOV_POWERSAVE
diff --git a/drivers/cpufreq/cpufreq.c b/drivers/cpufreq/cpufreq.c
index bcdef01234..bcdef34567 100644
--- a/drivers/cpufreq/cpufreq.c
+++ b/drivers/cpufreq/cpufreq.c
@@ -52,6 +52,15 @@
  *   Infinity Kernel: Added input boost and HMP tuning
  */

+/* Infinity Kernel - CPU Boost Parameters */
+#ifdef CONFIG_INFINITY_KERNEL
+unsigned int infinity_input_boost_freq = 1497600;
+module_param_named(input_boost_freq, infinity_input_boost_freq, uint, 0644);
+MODULE_PARM_DESC(input_boost_freq, "CPU frequency to boost to on input (kHz)");
+
+unsigned int infinity_input_boost_duration_ms = 500;
+module_param_named(input_boost_duration, infinity_input_boost_duration_ms, uint, 0644);
+MODULE_PARM_DESC(input_boost_duration, "Duration of input boost in ms");
+#endif
+
 static LIST_HEAD(cpufreq_policy_list);

 /* Async migration flags */
@@ -614,6 +623,29 @@ static ssize_t show_scaling_governor(struct cpufreq_policy *policy, char *buf)
 	return sprintf(buf, "%s\n", policy->governor->name);
 }

+#ifdef CONFIG_INFINITY_KERNEL
+/*
+ * infinity_cpufreq_boost - Apply an input-driven CPU frequency boost
+ * @policy: CPUFreq policy
+ *
+ * Temporarily raises the minimum frequency to provide better
+ * responsiveness during touch events, scrolling, and gaming.
+ * The frequency returns to normal after boost_duration_ms.
+ */
+void infinity_cpufreq_boost(struct cpufreq_policy *policy)
+{
+	unsigned int freq;
+
+	if (!policy || !policy->governor)
+		return;
+
+	freq = infinity_input_boost_freq;
+
+	if (freq > policy->min)
+		cpufreq_driver_target(policy, freq, CPUFREQ_RELATION_L);
+
+	mod_delayed_work(system_wq, &policy->transition_task,
+			 msecs_to_jiffies(infinity_input_boost_duration_ms));
+}
+#endif
+
 /*
  * Stores policy appropriate boost value
  */
diff --git a/drivers/cpufreq/cpufreq_ondemand.c b/drivers/cpufreq/cpufreq_ondemand.c
index cdef012345..cdef456789 100644
--- a/drivers/cpufreq/cpufreq_ondemand.c
+++ b/drivers/cpufreq/cpufreq_ondemand.c
@@ -1,4 +1,4 @@
-/*
+/*
  *  drivers/cpufreq/cpufreq_ondemand.c
  *
  *  Copyright (C)  2001 Russell King
@@ -17,8 +17,11 @@
  *
  * Infinity Kernel modifications:
  *   - Faster ramp-up for gaming responsiveness
+ *   - Optimized load thresholds
+ *   - Touch boost integration
+ *   - HMP-aware frequency selection
  */

 #define pr_fmt(fmt) KBUILD_MODNAME ": " fmt

 #include <linux/cpu.h>
@@ -36,9 +39,16 @@
 #include "cpufreq_ondemand.h"

+/* Infinity Kernel Tunables */
+#ifdef CONFIG_INFINITY_KERNEL
+#define INFINITY_SAMPLING_DOWN_FACTOR   4
+#define INFINITY_UP_THRESHOLD          65
+#define INFINITY_DOWN_THRESHOLD        30
+#define INFINITY_SAMPLING_RATE         20000
+#else
 #define DEF_SAMPLING_DOWN_FACTOR       (100 * cpu_sampling_rate / 20000)
 #define DEF_FREQUENCY_UP_THRESHOLD     (80)
 #define DEF_FREQUENCY_DOWN_THRESHOLD   (20)
+#endif

 static int do_dbs_timer(struct work_struct *work);
 static int should_set_freq(struct od_dbs_tuners *dbs_tuners,
@@ -55,12 +65,22 @@ static DEFINE_PER_CPU(struct od_cpu_dbs_info_s, od_cpu_dbs_info);

 static unsigned int default_powersave_bias;
+#ifdef CONFIG_INFINITY_KERNEL
+/*
+ * Infinity Kernel: Optimized ondemand parameters
+ *
+ * - sampling_rate: 20ms (faster response to load changes)
+ * - up_threshold: 65% (boost to max at 65% load instead of 80%)
+ * - down_threshold: 30% (stay at high freq longer)
+ * - sampling_down_factor: 4x (4x slower ramp down vs ramp up)
+ * - powersave_bias: 0 (no throttling in normal operation)
+ */
 static struct dbs_tuners {
 	unsigned int sampling_rate;
 	unsigned int sampling_down_factor;
 	unsigned int up_threshold;
 	unsigned int down_threshold;
-	unsigned int powersave_bias;
+	unsigned int powersave_bias; /* 0 = no bias, max performance */
 	unsigned int io_is_busy;
 	unsigned int ignore_nice_load;
 } od_tuners_ins = {
@@ -69,10 +89,13 @@ static struct dbs_tuners {
 	.sampling_down_factor = DEF_SAMPLING_DOWN_FACTOR,
 	.up_threshold = DEF_FREQUENCY_UP_THRESHOLD,
 	.down_threshold = DEF_FREQUENCY_DOWN_THRESHOLD,
-	.powersave_bias = default_powersave_bias,
+	.powersave_bias = 0, /* Infinity: no power bias for gaming */
 	.io_is_busy = 1, /* Infinity: always consider IO as busy */
-	.ignore_nice_load = 0,
+	.ignore_nice_load = 1, /* Infinity: ignore nice for better response */
+	.sampling_rate = INFINITY_SAMPLING_RATE, /* 20ms */
+	.up_threshold = INFINITY_UP_THRESHOLD,   /* 65% */
+	.down_threshold = INFINITY_DOWN_THRESHOLD, /* 30% */
 };
+#endif

 static inline struct od_cpu_dbs_info_s *get_od_cpu_dbs_info_s(
 					unsigned int cpu)
@@ -215,10 +238,35 @@ static void dbs_freq_increase(struct cpufreq_policy *p, unsigned int freq)
  */
 static void od_check_cpu(struct od_cpu_dbs_info_s *dbs_info)
 {
-	struct od_dbs_tuners *od_tuners = dbs_info->cdbs.cur_policy->governor_data;
+	struct od_dbs_tuners *od_tuners =
+		dbs_info->cdbs.cur_policy->governor_data;
 	struct dbs_data *dbs_data = dbs_info->cdbs.dbs_data;
 	struct cpufreq_policy *policy = dbs_info->cdbs.cur_policy;
 	unsigned int load = dbs_info->cdbs.prev_cpu_load;

+#ifdef CONFIG_INFINITY_KERNEL
+	/* Infinity Kernel: Aggressive boost for high-load scenarios */
+	if (load > 85) {
+		/* At very high load, jump to max frequency immediately */
+		dbs_freq_increase(policy, policy->max);
+		return;
+	}
+
+	if (load > od_tuners->up_threshold) {
+		/* Above threshold: boost to next frequency step */
+		unsigned int next_freq = policy->cur;
+		unsigned int i;
+
+		/* Find the next available frequency above current */
+		for (i = 0; i < policy->freq_table_size - 1; i++) {
+			if (policy->freq_table[i].frequency == policy->cur) {
+				next_freq = policy->freq_table[i + 1].frequency;
+				break;
+			}
+		}
+		dbs_freq_increase(policy, next_freq);
+		return;
+	}
+#else
 	dbs_info->freq_lo = UINT_MAX;

 	/* Check for frequency increase */
@@ -233,6 +281,7 @@ static void od_check_cpu(struct od_cpu_dbs_info_s *dbs_info)
 	} else {
 		dbs_info->rate_mult = 1;
 	}
+#endif

 	/* Check for frequency decrease */
 	if (load < od_tuners->down_threshold) {
@@ -382,3 +431,21 @@ static int __init cpufreq_gov_dbs_init(void)
 }
 module_init(cpufreq_gov_dbs_init);

+#ifdef CONFIG_INFINITY_KERNEL
+/* Infinity Kernel: Export CPU boost for input subsystem */
+EXPORT_SYMBOL_GPL(infinity_cpufreq_boost);
+
+/* Infinity Kernel sysfs for runtime tuning */
+static ssize_t show_infinity_boost(struct kobject *kobj,
+				   struct kobj_attribute *attr, char *buf)
+{
+	return sprintf(buf, "%u\n", infinity_input_boost_freq);
+}
+
+static ssize_t store_infinity_boost(struct kobject *kobj,
+				    struct kobj_attribute *attr,
+				    const char *buf, size_t count)
+{
+	unsigned int val;
+	if (sscanf(buf, "%u", &val) == 1 && val >= 300000 && val <= 2208000) {
+		infinity_input_boost_freq = val;
+	}
+	return count;
+}
+#endif

--
