 #include <linux/module.h>
@@ -13,41 +39,74 @@
 #define SHIP_MODE_PULSE_TIME_MS		32
 
 /* Thermal monitoring */
-#define THERMAL_POLL_INTERVAL_MS		1000
+#define THERMAL_POLL_INTERVAL_MS		500
