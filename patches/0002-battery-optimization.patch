-#define CHARGE_CURRENT_FCC_DEFAULT_MA		2000
-#define CHARGE_CURRENT_TRICKLE_MA		300
-#define CHARGE_CURRENT_PRECHARGE_MA		300
+/* Charging limits - Infinity Kernel "Cool Charge" profile */
+#define CHARGE_CURRENT_FCC_MAX_MA		2048  /* 0.4C for 5160mAh */
+#define CHARGE_CURRENT_FCC_DEFAULT_MA		1600  /* conservative default */
+#define CHARGE_CURRENT_TRICKLE_MA		100   /* gentle top-up, no heat */
+#define CHARGE_CURRENT_PRECHARGE_MA		150   /* safe for depleted cells */
 
 /*
- * Fast Charge Current (FCC) table
+ * Fast Charge Current (FCC) table - Infinity Kernel Cool Charge profile
  *
  * The FCC table governs how much current the SMB2 PMIC pushes into
  * the battery during constant-current phase.
+ *
+ * Infinity Kernel: Tuned for the 5160mAh Li-Po cell in vayu/bhima.
+ *    Battery University recommendation: charge at 0.3C-0.5C for best
+ *    longevity. At 0.4C the cell stays well below the 45 degC damage
+ *    threshold even under sustained charge.
+ *
+ *  - Input current capped at 2000mA. The PMI8998 PMIC dissipates
+ *    significant heat when bucking high-voltage input to battery
+ *    voltage. Limiting input power directly reduces PMIC die temp.
  */
 static const int smb2_fcc_table[] = {
-	/* USB 2.0 (500mA port) */	500,
-	/* USB 3.0 (900mA port) */	900,
-	/* PD 5V */			1500,
-	/* PD 9V */			3000,
-	/* QC 2.0 */			3000,
-	/* QC 3.0 */			3000,
+	/* USB 2.0 (500mA port) */	 500,
+	/* USB 3.0 (900mA port) */	 900,
+	/* PD 5V */			 1500,
+	/* PD 9V */			 2048,  /* was 3000: 0.4C cap */
+	/* QC 2.0 */			 2048,  /* was 3000: 0.4C cap */
+	/* QC 3.0 */			 2048,  /* was 3000: 0.4C cap */
+	/* Proprietary/33W */		 2048,  /* force safe rate always */
 };
 
+/* Input current limit - Infinity Kernel: hard cap regardless of charger */
+static int input_current_limit_ma = 2000;
+module_param(input_current_limit_ma, int, 0644);
+
 /*
  * Infinity Kernel: Battery/skin temperature derating table.
  *
  * Battery/skin temperature derating table (index = severity level).
  *
  * Stock table only starts derating above 40 degC -- far too late.
- * The cell is already under thermal stress by that point.
+ * The cell is already under thermal stress by that point. The PMIC
+ * should begin stepping down at 35 degC to keep skin temp at/below
+ * 37 degC (body temperature) so the phone feels cool to the touch.
+ *
+ * Temperature thresholds (battery NTC reading):
+ *   < 35 degC : Full FCC (2048mA)
+ *   35-38 degC : 1600mA    (gentle reduction)
+ *   38-41 degC : 1200mA    (noticeable step-down)
+ *   41-43 degC :  800mA    (significant, PMIC cooling)
+ *   43-45 degC :  500mA    (very conservative, heat escaping)
+ *   > 45 degC  :  300mA    (trickle only, fast charge disabled)
  */
 static const int smb2_thermal_fcc_table[] = {
-	500, 1000, 1500, 2000, 2500, 3000,
+	/* Level 5: cool (< 35 degC)  */	2048,
+	/* Level 4: warm (35-38 degC) */	1600,
+	/* Level 3: hot  (38-41 degC) */	1200,
+	/* Level 2: vhot (41-43 degC) */	 800,
+	/* Level 1: crit (43-45 degC) */	 500,
+	/* Level 0: emer (> 45 degC)  */	 300,
 };
 
+/* Number of thermal derating steps */
+#define THERMAL_FCC_TABLE_SIZE		(ARRAY_SIZE(smb2_thermal_fcc_table))
+
 /*
  * Infinity Kernel: JEITA temperature compliance table.
  *
@@ -56,23 +115,99 @@ static const int smb2_thermal_fcc_table[] = {
  * prevent permanent damage and ensure safe operation across the
  * full operating range.
  *
- * TODO: Add full JEITA ranges
+ * Temp range     | Action                 | FCC limit
+ * ---------------|------------------------|----------
+ *   < 0 degC     | NO CHARGING (plating)  |    0 mA
+ *   0-10 degC    | Cold weather protect   |  500 mA
+ *  10-45 degC    | Normal (use table)     | table
+ *  45-50 degC    | Hot derate             |  500 mA
+ *  > 50 degC     | STOP CHARGING          |    0 mA
+ *
+ * JEITA thresholds in deci-Celsius (multiply degC by 10):
+ */
+#define JEITA_TEMP_NOCHARGE_HIGH_DECI_C	500  /* 50.0 degC */
+#define JEITA_TEMP_NOCHARGE_LOW_DECI_C		0    /*  0.0 degC */
+#define JEITA_TEMP_HOT_HIGH_DECI_C		450  /* 45.0 degC */
+#define JEITA_TEMP_COOL_LOW_DECI_C		100  /* 10.0 degC */
+
+/* JEITA FCC limits */
+#define JEITA_FCC_NOCHARGE_MA			0    /* Absolute cutoff */
+#define JEITA_FCC_COLD_MA			500  /* 0-10 degC protection */
+#define JEITA_FCC_HOT_MA			500  /* 45-50 degC protection */
+#define JEITA_FCC_NORMAL_MA			(-1) /* Use thermal derating table */
+
+/*
+ * Map battery temperature (deci-Celsius) to JEITA FCC limit.
+ * Called from the thermal monitoring workqueue.
+ */
+static int smb2_get_jeita_fcc_limit(int temp_decic)
+{
+	if (temp_decic <= JEITA_TEMP_NOCHARGE_LOW_DECI_C) {
+		/* Below 0 degC: lithium plating risk, NO CHARGING */
+		pr_warn("smb2: JEITA cold shutdown, temp=%d.%d\n",
+				temp_decic / 10, abs(temp_decic % 10));
+		return JEITA_FCC_NOCHARGE_MA;
+	}
+	if (temp_decic <= JEITA_TEMP_COOL_LOW_DECI_C) {
+		/* 0-10 degC: reduced current, high internal resistance */
+		pr_info("smb2: JEITA cold limit, FCC=500mA\n");
+		return JEITA_FCC_COLD_MA;
+	}
+	if (temp_decic <= JEITA_TEMP_HOT_HIGH_DECI_C) {
+		/* 10-45 degC: normal, use thermal derating table */
+		return JEITA_FCC_NORMAL_MA;
+	}
+	if (temp_decic <= JEITA_TEMP_NOCHARGE_HIGH_DECI_C) {
+		/* 45-50 degC: hot derate, 500mA trickle to cool down */
+		pr_warn("smb2: JEITA hot limit, FCC=500mA\n");
+		return JEITA_FCC_HOT_MA;
+	}
+	/* Above 50 degC: EMERGENCY STOP */
+	pr_crit("smb2: JEITA thermal shutdown, STOP CHARGING\n");
+	return JEITA_FCC_NOCHARGE_MA;
+}
+
+/*
+ * Apply combined JEITA + thermal derating to get effective FCC.
+ * JEITA is the outer safety envelope; thermal derating fine-tunes
+ * within the normal operating window (10-45 degC).
+ */
+static int smb2_get_effective_fcc(int temp_decic, int thermal_level)
+{
+	int jeita_fcc = smb2_get_jeita_fcc_limit(temp_decic);
+
+	if (jeita_fcc == JEITA_FCC_NORMAL_MA
+			&& thermal_level < THERMAL_FCC_TABLE_SIZE)
+		return smb2_thermal_fcc_table[thermal_level];
+
+	return min(jeita_fcc, smb2_thermal_fcc_table[thermal_level]);
+}
+
+/*
+ * Infinity Kernel: Trickle charge configuration.
+ *
+ * When the battery approaches 100%, the SMB2 transitions to trickle
+ * charge. Stock 300mA at this phase still generates measurable heat
+ * because the cell voltage is at its peak. Dropping to 100mA makes
+ * the final 95-100% phase essentially thermally neutral while adding
+ * only ~15 minutes to full charge.
  */
-#define JEITA_TEMP_COLD_MA			500
-#define JEITA_TEMP_COOL_MA			1500
-#define JEITA_TEMP_WARM_MA			1000
-#define JEITA_TEMP_HOT_MA			500
 
 /*
  * Infinity Kernel: Input current limit enforcement.
  *
  * Even when connected to a 33W (QC3.0 9V/3A) charger, we only pull
- * max from USB. This reduces heat in three places:
+ * 2000mA max from USB. This reduces heat in three places:
  *   1. The USB-C connector and cable (less I^2R loss)
- *   2. The PMI8998 PMIC input FETs
- *   3. The PMI8998 switching buck converter
+ *   2. The PMI8998 PMIC input FETs (lower conduction loss)
+ *   3. The PMI8998 switching buck converter (lower switching loss)
+ *
+ * At 5V/2A input (10W), PMIC efficiency is ~92%. At 9V/3A (27W),
+ * efficiency drops to ~85% due to the higher buck ratio, meaning ~4W
+ * is dissipated as heat in the PMIC alone. At 5V/2A, only ~0.8W is
+ * wasted. That 3.2W difference is warm phone vs hot phone.
  */
-#define SMB2_INPUT_CURRENT_LIMIT_MA		3000
+#define SMB2_INPUT_CURRENT_LIMIT_MA		2000
 
 /*
  * Infinity Kernel: Fast charge enable/disable logic.
@@ -80,12 +215,15 @@ static const int smb2_thermal_fcc_table[] = {
  * When thermal derating hits the lowest level (> 45 degC), we disable
  * fast charge entirely to let the system cool passively.
  */
-#define THERMAL_FCC_FASTCHARGE_DISABLE_MA	500
+#define THERMAL_FCC_FASTCHARGE_DISABLE_MA	300
 
 static bool smb2_is_fastcharge_allowed(int fcc_ma)
 {
-	if (fcc_ma <= THERMAL_FCC_FASTCHARGE_DISABLE_MA)
+	if (fcc_ma <= THERMAL_FCC_FASTCHARGE_DISABLE_MA) {
+		pr_info("smb2: fast charge disabled, FCC=%dmA <= threshold\n",
+				fcc_ma);
 		return false;
+	}
 	return true;
 }
 
@@ -113,7 +251,15 @@ static int smb2_apply_input_current_limit(struct smb2_charger *chg, int requeste
 {
 	int effective_ma;
 
-	effective_ma = min(requested_ma, SMB2_INPUT_CURRENT_LIMIT_MA);
+	effective_ma = min(requested_ma, input_current_limit_ma);
+	effective_ma = min(effective_ma, SMB2_INPUT_CURRENT_LIMIT_MA);
+
+	if (effective_ma < requested_ma) {
+		pr_info("smb2: input ICL clamped %d -> %dmA (cap=%d, mod=%d)\n",
+				requested_ma, effective_ma,
+				SMB2_INPUT_CURRENT_LIMIT_MA,
+				input_current_limit_ma);
+	}
 
 	return smb2_set_prop_input_current_trim(chg, effective_ma);
 }
@@ -137,7 +283,7 @@ static void smb2_thermal_work(struct work_struct *work)
 	int thermal_level;
 	int fcc_ma;
 
-	/* Poll battery temperature and determine thermal severity */
+	/* Poll battery temperature and determine thermal severity (every 500ms) */
 	rc = smb2_get_prop_batt_temp(chg, &batt_temp);
 	if (rc < 0) {
 		pr_err("smb2: failed to read battery temp, rc=%d\n", rc);
@@ -146,13 +292,27 @@ static void smb2_thermal_work(struct work_struct *work)
 
 	thermal_level = smb2_get_thermal_level(chg, batt_temp);
 
-	/* Look up FCC from thermal derating table */
-	if (thermal_level < ARRAY_SIZE(smb2_thermal_fcc_table))
-		fcc_ma = smb2_thermal_fcc_table[thermal_level];
-	else
-		fcc_ma = smb2_thermal_fcc_table[ARRAY_SIZE(smb2_thermal_fcc_table) - 1];
+	/*
+	 * Look up effective FCC using combined JEITA + thermal derating.
+	 * JEITA provides hard safety limits; thermal table provides
+	 * graduated reduction within the safe window.
+	 */
+	fcc_ma = smb2_get_effective_fcc(batt_temp, thermal_level);
+
+	if (fcc_ma == 0) {
+		/* JEITA says stop charging entirely */
+		smb2_set_prop_charge_disable(chg, true);
+		pr_warn("smb2: charge disabled by JEITA, temp=%d\n", batt_temp);
+	} else {
+		/* Within safe range, apply FCC */
+		smb2_set_prop_fcc(chg, fcc_ma);
+		smb2_set_prop_charge_disable(chg, false);
+	}
 
-	smb2_set_prop_fcc(chg, fcc_ma);
+	pr_info("smb2: thermal loop: temp=%d.%d level=%d FCC=%dmA fastchg=%d\n",
+			batt_temp / 10, abs(batt_temp % 10),
+			thermal_level, fcc_ma,
+			smb2_is_fastcharge_allowed(fcc_ma));
 
 	/* Re-schedule thermal monitoring */
 	schedule_delayed_work(&chg->thermal_work,
