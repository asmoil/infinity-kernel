# Infinity Charging Control - Kconfig
# Poco X3 Pro (vayu/bhima) | SM8150

config CHARGING_CONTROL
    tristate "Infinity Charging Control (Gaming Bypass)"
    depends on POWER_SUPPLY && THERMAL
    default y
    help
      Infinity Kernel charging bypass control for gaming.
      Provides 5 modes via sysfs: bypass, normal, 80%, 90%, custom.
      Also accessible via IOCTL through /dev/infinity_charging_control.