#
# Infinity Charging Control Driver
# For Poco X3 Pro (vayu/bhima) - SM8150/SM8250
#
menu "Device Drivers"
    comment "Infinity Kernel Charging Control"

config CHARGING_CONTROL
    tristate "Infinity Charging Control (Gaming Bypass)"
    depends on POWER_SUPPLY && THERMAL
    default y
    help
      Infinity Kernel charging bypass control for gaming.
      Provides sysfs interface at /sys/kernel/infinity_charging/
      with charging mode selection and thermal monitoring.

endif # menu