#
# Infinity Kernel Defconfig
# Poco X3 Pro (vayu/bhima) - SM8250-AC (Snapdragon 860)
# Linux 4.14.180 | Proton Clang 17
# Fragment merged on top of vayu_defconfig
#

#
# CPU & Timer
#
CONFIG_NR_CPUS=8
CONFIG_HZ_300=y
# CONFIG_NO_HZ_FULL is not set
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
# CONFIG_CPU_FREQ_GOV_INTERACTIVE is not set
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_SCHED_WALT=y
CONFIG_SCHED_TUNE=y

#
# Memory
#
CONFIG_ZRAM=y
CONFIG_ZRAM_LZ4_COMPRESS=y
CONFIG_KSM=y
CONFIG_KSM_RUN_DEFAULT=1
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=256
CONFIG_MEMORY_ISOLATION=y

#
# Filesystems & SUFS
#
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_DECOMP_SINGLE=y
CONFIG_SUFS_FS=y
CONFIG_FHANDLE=y

#
# Networking / TCP
#
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_BBR=y
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_TCP_CONG_HTCP=y
CONFIG_TCP_FACK=y
CONFIG_TCP_FASTOPEN=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_PIE=y

#
# I/O & FSYNC
#
CONFIG_FSYNC=y
CONFIG_IOSCHED_DEADLINE=y
# CONFIG_IOSCHED_CFQ is not set
CONFIG_IOSCHED_BFQ=y
CONFIG_IOSCHED_MAPLE=y
# CONFIG_CFQ_GROUP_IOSCHED is not set
CONFIG_BFQ_GROUP_IOSCHED=y
CONFIG_BLOCK=y
CONFIG_MD=y

#
# Tracing (root manager support)
#
CONFIG_STACKTRACE=y
CONFIG_SCHED_INFO=y
CONFIG_KPROBES=y
CONFIG_UPROBES=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y
CONFIG_ENABLE_DEFAULT_TRACERS=y
CONFIG_TRACER_SNAPSHOT=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
# CONFIG_BPF_JIT_ALWAYS_ON is not set
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_PERF_EVENTS=y

#
# GPU (Adreno 618)
#
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_MSM_KGSL=y
# CONFIG_DEBUG_KGSL is not set
# CONFIG_KGSL_PERFCTRL is not set
CONFIG_MSM_ADRENO_DEFAULT_GOVERNOR="msm-adreno-tz"

#
# Modules & Root Manager Support
#
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
# CONFIG_MODULE_SIG is not set
# CONFIG_MODULE_SIG_HASH is not set
CONFIG_MODULE_FORCE_LOAD=y
# CONFIG_MODVERSIONS is not set
# CONFIG_STRICT_MODULE_RWX is not set

#
# Thermal & Power
#
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_USER_SPACE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_QCOM_SPMI_TEMP_ALARM=y
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_SMB2=y
CONFIG_QCOM_SMB2_CHARGER=y

#
# Charging Driver (Infinity)
#
CONFIG_CHARGING_CONTROL=y

#
# Security (root manager friendly)
#
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
# CONFIG_HARDENED_USERCOPY is not set
CONFIG_STRICT_KERNEL_RWX=y

#
# Debug (minimal, production)
#
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_INFO_REDUCED is not set
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

#
# Disable Clang-incompatible subsystems (not needed on phone)
#
# CONFIG_RC_CORE is not set
# CONFIG_MEDIA_RC_SUPPORT is not set
# CONFIG_LIRC is not set
# CONFIG_V4L_PLATFORM_DRIVERS is not set
# CONFIG_V4L_MEM2MEM_DRIVERS is not set
# CONFIG_RADIO_ADAPTERS is not set
# CONFIG_VIDEO_DEV is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_DRM_LEGACY is not set
# CONFIG_AGP is not set
# CONFIG_INFINIBAND is not set
# CONFIG_FAULT_INJECTION is not set
# CONFIG_SAMPLES is not set
# CONFIG_MFD_SPK_ID is not set

#
# Other Optimizations
#
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_COMPACTION=y
CONFIG_HUGETLBFS=y
CONFIG_MEMCG=y
CONFIG_BLK_DEV_THROTTLING=y