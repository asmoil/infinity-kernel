#
# Infinity Kernel Defconfig Fragment
# Poco X3 Pro (vayu/bhima) - SM8150 (LineageOS base)
# Linux 4.14.357 | Clang 23
# Fragment merged on top of vendor/sm8150_defconfig
#

# CPU & Timer
CONFIG_HZ_300=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y

# Memory
CONFIG_ZRAM=y
CONFIG_ZRAM_LZ4_COMPRESS=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_KSM=y
CONFIG_KSM_RUN_DEFAULT=1
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=256
CONFIG_MEMORY_ISOLATION=y

# Filesystems
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_DECOMP_SINGLE=y
CONFIG_FHANDLE=y

# Networking / TCP
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_BBR=y
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_TCP_CONG_HTCP=y
CONFIG_TCP_FACK=y
CONFIG_TCP_FASTOPEN=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_PIE=y

# I/O & FSYNC
CONFIG_FSYNC=y
CONFIG_IOSCHED_DEADLINE=y
CONFIG_IOSCHED_BFQ=y
CONFIG_IOSCHED_MAPLE=y
CONFIG_BFQ_GROUP_IOSCHED=y
CONFIG_BLOCK=y
CONFIG_MD=y

# Tracing (root manager support)
CONFIG_KPROBES=y
CONFIG_UPROBES=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y
CONFIG_ENABLE_DEFAULT_TRACERS=y
CONFIG_TRACER_SNAPSHOT=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_PERF_EVENTS=y

# GPU (Adreno 640 for SM8150)
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_MSM_KGSL=y

# Modules & Root Manager Support
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_LOAD=y

# Thermal & Power
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_USER_SPACE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y
CONFIG_QCOM_SPMI_TEMP_ALARM=y
CONFIG_POWER_SUPPLY=y

# Charging Driver (Infinity)
CONFIG_CHARGING_CONTROL=y

# Security
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_STRICT_KERNEL_RWX=y

# Debug (minimal, production)
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# Other Optimizations
CONFIG_ENERGY_MODEL=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_COMPACTION=y
CONFIG_HUGETLBFS=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_PAGE_POISONING=y