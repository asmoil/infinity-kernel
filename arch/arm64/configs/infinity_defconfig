# Infinity Kernel — Kconfig fragment for Poco X3 Pro (vayu/bhima)
# Merge on top of vendor/sm8150_defconfig (LineageOS base)
#
# Timer tick
CONFIG_HZ_300=y
# CONFIG_HZ_250 is not set
# CONFIG_HZ_1000 is not set
CONFIG_HZ=300

# Scheduler
CONFIG_SCHED_WALT=y

# CPUFreq
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# I/O schedulers
CONFIG_IOSCHED_BFQ=y
CONFIG_IOSCHED_MAPLE=y
CONFIG_CFQ_GROUP_IOSCHED=y

# ZRAM
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_LZ4_COMPRESS=y

# KSM
CONFIG_KSM=y

# FSYNC
CONFIG_FSYNC=y

# Energy Aware Scheduling
CONFIG_ENERGY_MODEL=y

# Memory management
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=256
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y

# Networking
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_PIE=y
CONFIG_TCP_FASTOPEN=y

# Security
CONFIG_HARDENED_USERCOPY=y
CONFIG_PAGE_POISONING=y
CONFIG_DEBUG_RODATA=y

# Debugging (for kprobes, BPF)
CONFIG_KPROBES=y
CONFIG_BPF_SYSCALL=y

# Display
CONFIG_DRM_MSM=y

# Charging control
CONFIG_CHARGING_CONTROL=y